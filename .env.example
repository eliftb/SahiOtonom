# ── Loglama ──────────────────────────────────────────────────────────────────
# DEBUG  → tüm loglar (callback başına detay, yüksek hacim)
# INFO   → rutin durum değişiklikleri (varsayılan)
# WARN   → yalnızca uyarı + hata
# ERROR  → yalnızca hata
LOG_LEVEL=INFO

# ── Serial / UART ─────────────────────────────────────────────────────────────
# Bu portlar donanıma ve USB bağlantı sırasına göre değişebilir.
# 'ls /dev/ttyACM*' komutuyla mevcut portları listeleyin.
SERIAL_SPEED_PORT=/dev/ttyACM1
SERIAL_STEERING_PORT=/dev/ttyACM0
SERIAL_STOP_PORT=/dev/ttyACM2
SERIAL_BAUD_RATE=38400

# ── PID Kontrolör ─────────────────────────────────────────────────────────────
# Lateral deviation → direksiyon açısı dönüşümü için PID kazançları.
# Araç testi sırasında bu değerleri ayarlayın.
PID_KP=0.05
PID_KI=0.5
PID_KD=1.0
PID_INTEGRAL_CLAMP=0.3

# ── Kamera ────────────────────────────────────────────────────────────────────
# Geçerli çözünürlükler: HD720 | HD1080 | HD2K | VGA
# Yüksek çözünürlük → daha fazla işlem yükü
CAMERA_RESOLUTION=HD720
CAMERA_FPS=30

# ── OpenCV Ekran Görüntüsü ───────────────────────────────────────────────────
# true  → imshow pencereleri açılır (geliştirme / debug)
# false → pencere açılmaz, headless çalışır (yarışma / sunucu)
CV_DISPLAY=true

# ── Web Arayüzü (Node.js Backend) ────────────────────────────────────────────
BACKEND_PORT=3001
